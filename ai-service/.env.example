# ai-service/.env — copy to ai-service/.env and fill in real values.
# This file is safe to commit; it contains NO real credentials.

# ── Internal auth token (must match core INTERNAL_TOKEN) ─────────────────────
INTERNAL_TOKEN=your-internal-token-here

# ── DeepFace face recognition model ─────────────────────────────────────────
# Options: VGG-Face, Facenet, ArcFace, Dlib, SFace
FACE_MODEL=ArcFace

# ── EasyOCR languages ────────────────────────────────────────────────────────
OCR_LANGS=en,hi
