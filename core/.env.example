# core/.env — copy to core/.env and fill in real values.
# This file is safe to commit; it contains NO real credentials.

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Direct connection (used by Prisma Migrate — bypasses PgBouncer)
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── JWT secrets (min 32 random chars — generate with: openssl rand -hex 32) ───
ACCESS_SECRET=replace_with_random_32_char_secret
REFRESH_SECRET=replace_with_another_random_32_char_secret

# ── Internal service communication ───────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_TOKEN=replace_with_random_token

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Option 1 (recommended): Gmail with App Password
#   1. Enable 2-Step Verification on your Google account
#   2. Generate App Password at: https://myaccount.google.com/apppasswords
#   3. Fill in values below (use the 16-char app password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_SECURE=false
SMTP_FROM="VeriKYC" <your-gmail@gmail.com>
#
# Option 2 (local dev, no internet): Mailpit
#   Install: winget install axllent.mailpit  |  run: mailpit
#   SMTP: localhost:1025  |  UI: http://localhost:8025
#   SMTP_HOST=localhost  SMTP_PORT=1025  (leave USER/PASS empty)
#
# Option 3 (production): any transactional SMTP (SendGrid, SES, Postmark, etc.)

# ── Google Gemini (powers the conversational Agent Chat layer) ───────────────
# Get a key at https://aistudio.google.com/apikey (free tier available).
# Without this set, free-text chat messages return a clear "not configured"
# error — exact tool calls (button clicks, the password modal) are unaffected.
GEMINI_API_KEY=replace_with_real_key
GEMINI_MODEL=gemini-2.5-flash

# ── Upstash Redis (rate-limiter store — required in production) ───────────────
# Free tier at https://console.upstash.com — create a Redis database.
# In the Upstash dashboard use "Connect" → "ioredis" to copy the Redis URL.
# Format: rediss://default:PASSWORD@HOST.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:your_token@your-db.upstash.io:6379

# ── SSL workaround (dev only — remove in production) ─────────────────────────
# Required on machines where npm/Prisma downloads fail with UNABLE_TO_VERIFY_LEAF_SIGNATURE.
# Never set this in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0
