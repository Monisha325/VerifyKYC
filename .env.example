# Root-level env — copy to .env and fill in real values.
# This file is safe to commit; it contains NO real credentials.

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── JWT secrets (min 32 random chars each — generate with: openssl rand -hex 32) ──
ACCESS_SECRET=replace_with_random_32_char_secret
REFRESH_SECRET=replace_with_another_random_32_char_secret

# ── Internal service communication ───────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_TOKEN=replace_with_random_token
