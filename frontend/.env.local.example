# frontend/.env.local — copy to .env.local and fill in values.
# This file is safe to commit; it contains NO real credentials.

# ── API proxy ─────────────────────────────────────────────────────────────────
# BACKEND_URL is server-side only — Next.js proxies /api/v1/* to this origin.
# Set in Vercel env vars for production; never prefixed NEXT_PUBLIC_.
#   Dev:  http://localhost:4000
#   Prod: https://your-core-service.onrender.com
BACKEND_URL=http://localhost:4000

# NEXT_PUBLIC_API_URL is the path the browser uses.
# With the proxy active this should stay as /api/v1 (same-origin).
# Change only if bypassing the proxy entirely (e.g. mobile native clients).
NEXT_PUBLIC_API_URL=/api/v1
